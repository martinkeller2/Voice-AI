# ── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Deepgram (Speech-to-Text + Text-to-Speech) ───────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-asteria-en   # see https://developers.deepgram.com/docs/tts-models

# ── Groq (LLM) ───────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile   # or llama3-groq-70b-8192-tool-use-preview

# ── Public URL (ngrok or production hostname — must be https) ─────────────────
BASE_URL=https://your-ngrok-subdomain.ngrok.io
